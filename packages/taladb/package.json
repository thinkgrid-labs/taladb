{
  "name": "taladb",
  "version": "0.2.7",
  "description": "Local-first document and vector database for React, React Native, and Node.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "database",
    "local-first",
    "offline",
    "wasm",
    "react-native",
    "vector",
    "vector-search",
    "embeddings",
    "semantic-search",
    "ai",
    "hybrid-search"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkgrid-labs/taladb.git",
    "directory": "packages/taladb"
  },
  "homepage": "https://thinkgrid-labs.github.io/taladb/",
  "bugs": {
    "url": "https://github.com/thinkgrid-labs/taladb/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  },
  "optionalDependencies": {
    "@taladb/web": "workspace:*",
    "@taladb/node": "workspace:*"
  }
}
