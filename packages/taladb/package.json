{
  "name": "taladb",
  "version": "0.1.0",
  "description": "Local-first document database for React, React Native, and Node.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["database", "local-first", "offline", "wasm", "react-native"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  },
  "optionalDependencies": {
    "taladb-wasm": "workspace:*",
    "taladb-node": "workspace:*"
  }
}
