{
  "name": "taladb",
  "version": "0.7.9",
  "description": "Local-first document and vector database for React, React Native, and Node.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "react-native": "./dist/index.react-native.mjs",
      "browser": "./dist/index.browser.mjs",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "database",
    "local-first",
    "offline",
    "wasm",
    "react-native",
    "vector",
    "vector-search",
    "embeddings",
    "semantic-search",
    "ai",
    "hybrid-search"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkgrid-labs/taladb.git",
    "directory": "packages/taladb"
  },
  "homepage": "https://thinkgrid-labs.github.io/taladb/",
  "bugs": {
    "url": "https://github.com/thinkgrid-labs/taladb/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "@taladb/web": "workspace:*",
    "@taladb/node": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@taladb/web": {
      "optional": true
    },
    "@taladb/node": {
      "optional": true
    }
  }
}
