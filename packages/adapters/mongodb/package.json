{
  "name": "@taladb/sync-mongodb",
  "version": "0.8.5",
  "description": "MongoDB bidirectional sync adapter for TalaDB — sync a local TalaDB with a MongoDB collection, no intermediate API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "taladb",
    "mongodb",
    "sync",
    "replication",
    "local-first",
    "offline"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkgrid-labs/taladb.git",
    "directory": "packages/adapters/mongodb"
  },
  "homepage": "https://thinkgrid-labs.github.io/taladb/guide/bidirectional-sync",
  "bugs": {
    "url": "https://github.com/thinkgrid-labs/taladb/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "mongodb": ">=5.0.0",
    "taladb": "^0.8.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "mongodb": "^6.0.0",
    "taladb": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
