{
  "name": "@taladb/next",
  "version": "0.9.0",
  "description": "First-party Next.js integration for TalaDB — sync route handlers for the server, a SyncProvider for the client",
  "sideEffects": false,
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "database",
    "local-first",
    "nextjs",
    "sync",
    "offline",
    "taladb"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thinkgrid-labs/taladb.git",
    "directory": "packages/integrations/next"
  },
  "homepage": "https://taladb.dev/guide/bidirectional-sync",
  "bugs": {
    "url": "https://github.com/thinkgrid-labs/taladb/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@taladb/react": "^0.9.0",
    "react": ">=18.0.0",
    "taladb": "^0.9.0"
  },
  "peerDependenciesMeta": {
    "@taladb/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@taladb/node": "workspace:*",
    "@taladb/react": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "taladb": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
