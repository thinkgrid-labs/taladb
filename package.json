{
  "name": "taladb-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "pnpm run -r build",
    "build:wasm": "pnpm --filter taladb-wasm build",
    "build:node": "pnpm --filter taladb-node build",
    "test": "cargo test --workspace && pnpm run -r test",
    "test:rust": "cargo test --workspace",
    "test:wasm": "wasm-pack test packages/taladb-wasm --headless --chrome",
    "clean": "rimraf packages/*/pkg packages/*/dist packages/taladb-node/*.node target",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.5.0"
  }
}
