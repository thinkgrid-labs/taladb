{
  "name": "taladb-workspace",
  "private": true,
  "version": "0.8.5",
  "type": "module",
  "scripts": {
    "sync-version": "node scripts/sync-version.js",
    "dev:playground": "bash scripts/dev-playground.sh",
    "dev:playground-rn": "bash scripts/dev-playground-rn.sh --clean",
    "build": "pnpm run -r build",
    "build:taladb": "pnpm --filter taladb build",
    "build:web": "pnpm --filter @taladb/web build",
    "build:node": "pnpm --filter @taladb/node build",
    "build:react-native": "pnpm --filter @taladb/react-native build",
    "test": "cargo test --workspace && pnpm run -r test",
    "bench": "node scripts/bench.mjs",
    "bench:web": "node scripts/bench-web.mjs",
    "test:rust": "cargo test --workspace",
    "test:web": "wasm-pack test packages/taladb-web --headless --chrome",
    "clean": "rimraf packages/*/pkg packages/*/dist packages/taladb-node/*.node target",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.5.0"
  }
}